@page "/admin/game-list"
@rendermode InteractiveServer
@inject AuthenticationStateProvider GetAuthenticationStateAsync
@inject IGameAdminRepository GameAdminRepository
@attribute [StreamRendering]
@attribute [Authorize(Roles = "Admin")]

<PageTitle>Game List</PageTitle>

<section>
  <h1>Game List</h1>
  <article>
    <table class="table table-striped table-sm">
      <thead>
        <tr>
          <th scope="col">Id</th>

          <th scope="col">Name</th>
              @* ListHeaderCodePlaceholder *@

          <th scope="col">Actions</th>
        </tr>
      </thead>
      <tbody>
        @if (gamesAdminDto == null)
        {
          <tr>
            <td colspan="3">Loading...</td>
            @* LoadingCountCodePlaceholder *@
          </tr>
        }
        else if (gamesAdminDto.Count == 0)
        {
          <tr>
            @* ZeroCountCodePlaceholder *@
          </tr>
        }
        else
        {
          @foreach (var gameAdminDto in gamesAdminDto)
          {
            <tr>
              <td>@gameAdminDto.Id</td>

              <td>@gameAdminDto?.Name</td>
              @* ListItemCodePlaceholder *@

              <td>
                <a href="@("/admin/game-edit/" + gameAdminDto?.Id)">Edit</a>
              </td>
            </tr>
          }
        }
      </tbody>
    </table>
    <a href="/admin/game-edit">Create</a>
  </article>
</section>

@code {
  List<GameAdminDto>? gamesAdminDto = null;

  protected override async Task OnInitializedAsync()
  {
    var authState = await GetAuthenticationStateAsync.GetAuthenticationStateAsync();
    var userName = authState.User.Identity?.Name;

    if (userName == null)
    {
      return;
    }

    gamesAdminDto = await GameAdminRepository.GetAllAsync(userName);
  }
}
